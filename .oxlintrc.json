{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react", "import", "vitest"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "env": {
    "builtin": true,
    "browser": true,
    "node": true
  },
  "rules": {
    "no-console": "warn",
    "no-explicit-any": "warn",
    "react-in-jsx-scope": "off",
    "no-unassigned-import": "off",
    "no-empty-file": "off"
  }
}
