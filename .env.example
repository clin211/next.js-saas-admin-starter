# =============================================================================
# 环境变量样例。复制为 .env.local 后按需修改。
# 注意：Next 不会加载 .env.example，需复制为 .env.local 才会生效。
# =============================================================================

# 站点绝对地址（服务端解析同源 mock、生成元数据用）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 会话票据 HMAC 签名密钥（session-codec 用 WebCrypto HMAC-SHA256 签名/校验 cookie）。
# —— dev：内置默认值，留空即可，本地免配置。
# —— prod：必须设为强随机值，否则启动即抛错 fail-loud。
#           生成方式：openssl rand -base64 32
# AUTH_SECRET=

# 真实后端基地址（含前缀，如 https://api.example.com）。
# —— 留空 / 不设 → 开发期回落到同源 /api mock（app/api/*，可整目录删除）。
# —— 接真实后端：取消下行注释并改为你的地址，客户端零改动即可切换。
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api
